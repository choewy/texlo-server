{
  "name": "@texlo/server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prepare": "node scripts/prepare",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "dev": "concurrently -n admin,api,storage,worker -c auto \"pnpm admin:dev\" \"pnpm api:dev\" \"pnpm storage:dev\" \"pnpm worker:dev\"",
    "nest:g": "node scripts/nest/generate",
    "admin:dev": "nest start admin --watch",
    "admin:build": "nest build admin",
    "admin:prod": "node dist/apps/admin/src/main",
    "api:dev": "nest start api --watch",
    "api:build": "nest build api",
    "api:prod": "node dist/apps/api/src/main",
    "storage:dev": "nest start storage --watch",
    "storage:build": "nest build storage",
    "storage:prod": "node dist/apps/storage/src/main",
    "worker:dev": "nest start worker --watch",
    "worker:build": "nest build worker",
    "worker:prod": "node dist/apps/worker/src/main",
    "migration:build": "nest build migration",
    "migration:create": "typeorm migration:create apps/migration/src/migrations/migration",
    "migration:generate": "typeorm migration:generate -d dist/apps/migration/src/main apps/migration/src/migrations/migration",
    "migration:run": "node node_modules/typeorm/cli.js -d dist/apps/migration/src/main migration:run",
    "migration:revert": "node node_modules/typeorm/cli.js -d dist/apps/migration/src/main migration:revert",
    "test": "jest --config jest.config.json --passWithNoTests",
    "test:watch": "jest --config jest.config.json --watch",
    "test:cov": "jest --config jest.config.json --coverage"
  },
  "dependencies": {
    "@choewy/whisper": "^1.0.11",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.3.2",
    "@nestjs/typeorm": "^11.0.1",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.75.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "file-type": "^22.0.1",
    "ioredis": "^5.10.1",
    "mime-types": "^3.0.2",
    "mongodb": "^7.2.0",
    "mongoose": "^9.5.0",
    "nest-winston": "^1.10.2",
    "nestjs-cls": "^6.2.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "typeorm": "^0.3.28",
    "typeorm-naming-strategies": "^4.1.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "lint-staged": {
    "{src,apps,libs,test}/**/*.ts": "eslint --fix"
  }
}
