{
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".*\\.spec\\.ts$",
  "moduleFileExtensions": ["ts", "js", "json"],
  "modulePaths": ["<rootDir>"],
  "moduleNameMapper": {
    "^@apps/api/(.*)$": "<rootDir>/apps/api/src/$1",
    "^@libs/config$": "<rootDir>/libs/config/src",
    "^@libs/config/(.*)$": "<rootDir>/libs/config/src/$1",
    "^@libs/http$": "<rootDir>/libs/http/src",
    "^@libs/http/(.*)$": "<rootDir>/libs/http/src/$1",
    "^@libs/persistence$": "<rootDir>/libs/persistence/src",
    "^@libs/persistence/(.*)$": "<rootDir>/libs/persistence/src/$1",
    "^@libs/redis$": "<rootDir>/libs/redis/src",
    "^@libs/redis/(.*)$": "<rootDir>/libs/redis/src/$1"
  },
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/tsconfig.json",
        "diagnostics": false
      }
    ]
  },
  "collectCoverageFrom": ["apps/**/*.ts", "libs/**/*.ts", "!**/test/**/*.ts", "!**/index.ts"],
  "testPathIgnorePatterns": ["/node_modules/", "/dist/"]
}
